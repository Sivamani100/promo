{
  "ignoreCommand": "exit 0",
  "outputDirectory": "build/web",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/landing",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/landing/:path*",
      "destination": "/:path*",
      "permanent": false
    },
    {
      "source": "/reset-password",
      "destination": "/app/reset-password",
      "permanent": false
    },
    {
      "source": "/set-new-password",
      "destination": "/app/set-new-password",
      "permanent": false
    },
    {
      "source": "/login",
      "destination": "/app/login",
      "permanent": false
    },
    {
      "source": "/signup",
      "destination": "/app/signup",
      "permanent": false
    },
    {
      "source": "/auth/v1/callback",
      "destination": "/app/auth/v1/callback",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/app/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/app/icons/:path*",
      "destination": "/icons/:path*"
    },
    {
      "source": "/app/canvaskit/:path*",
      "destination": "/canvaskit/:path*"
    },
    {
      "source": "/app/:file.js",
      "destination": "/:file.js"
    },
    {
      "source": "/app/:file.wasm",
      "destination": "/:file.wasm"
    },
    {
      "source": "/app/:file.json",
      "destination": "/:file.json"
    },
    {
      "source": "/app/:file.png",
      "destination": "/:file.png"
    },
    {
      "source": "/app/:file.html",
      "destination": "/:file.html"
    },
    {
      "source": "/app",
      "destination": "/app/index.html"
    },
    {
      "source": "/app/",
      "destination": "/app/index.html"
    },
    {
      "source": "/app/:path*",
      "destination": "/app/index.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/features",
      "destination": "/features.html"
    },
    {
      "source": "/how-it-works",
      "destination": "/how-it-works.html"
    },
    {
      "source": "/faq",
      "destination": "/faq.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/escrow-guide",
      "destination": "/escrow-guide.html"
    },
    {
      "source": "/brand-guide",
      "destination": "/brand-guide.html"
    },
    {
      "source": "/influencer-guide",
      "destination": "/influencer-guide.html"
    },
    {
      "source": "/leaderboard",
      "destination": "/leaderboard.html"
    },
    {
      "source": "/discovery-feature",
      "destination": "/discovery-feature.html"
    },
    {
      "source": "/campaign-feature",
      "destination": "/campaign-feature.html"
    },
    {
      "source": "/collaboration-feature",
      "destination": "/collaboration-feature.html"
    },
    {
      "source": "/analytics-feature",
      "destination": "/analytics-feature.html"
    },
    {
      "source": "/help-center",
      "destination": "/help-center.html"
    },
    {
      "source": "/troubleshooting",
      "destination": "/troubleshooting.html"
    },
    {
      "source": "/getting-started",
      "destination": "/getting-started.html"
    },
    {
      "source": "/contact",
      "destination": "/contact.html"
    },
    {
      "source": "/community-guidelines",
      "destination": "/community-guidelines.html"
    },
    {
      "source": "/research",
      "destination": "/research.html"
    },
    {
      "source": "/beta",
      "destination": "/beta.html"
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy-policy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/delete-account",
      "destination": "/delete-account.html"
    },
    {
      "source": "/blog",
      "destination": "/blog/index.html"
    },
    {
      "source": "/blog/index",
      "destination": "/blog/index.html"
    },
    {
      "source": "/blog/platform-vs-agency",
      "destination": "/blog/platform-vs-agency.html"
    },
    {
      "source": "/blog/escrow-rise",
      "destination": "/blog/escrow-rise.html"
    },
    {
      "source": "/blog/escrow-benefits",
      "destination": "/blog/escrow-benefits.html"
    },
    {
      "source": "/blog/engagement-optimize",
      "destination": "/blog/engagement-optimize.html"
    },
    {
      "source": "/@:username",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "credentialless"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        }
      ]
    }
  ]
}
